# RunFabric — copy to .env and fill in values
# Generated for provider: aws-lambda, state: azblob

# Provider
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# State backend
AZURE_STORAGE_CONNECTION_STRING=
# or AZURE_STORAGE_ACCOUNT= + AZURE_STORAGE_KEY=
# Optional: RUNFABRIC_STAGE=dev
# Optional: RUNFABRIC_REAL_DEPLOY=1
