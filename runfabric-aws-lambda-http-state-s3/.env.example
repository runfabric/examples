# RunFabric — copy to .env and fill in values
# Generated for provider: aws-lambda, state: s3

# Provider
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# State backend
RUNFABRIC_S3_BUCKET=
RUNFABRIC_DYNAMODB_TABLE=
# Uses AWS_* from provider if same account
# Optional: RUNFABRIC_STAGE=dev
# Optional: RUNFABRIC_REAL_DEPLOY=1
