# RunFabric — copy to .env and fill in values
# Generated for provider: aws-lambda, state: gcs

# Provider
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# State backend
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Optional: RUNFABRIC_STAGE=dev
# Optional: RUNFABRIC_REAL_DEPLOY=1
