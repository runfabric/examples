# RunFabric — copy to .env and fill in values
# Generated for provider: aws-lambda, state: postgres

# Provider
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# State backend
RUNFABRIC_STATE_POSTGRES_URL=postgres://user:pass@localhost:5432/runfabric
# Optional: RUNFABRIC_STAGE=dev
# Optional: RUNFABRIC_REAL_DEPLOY=1
